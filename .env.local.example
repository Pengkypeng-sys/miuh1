# Spreadsheet ID dari URL: https://docs.google.com/spreadsheets/d/<INI>/edit
SPREADSHEET_ID=1vxmCCkfxAV_jBYKO9WjQGW1Ux7sFYNoQYHqrMrLkJSA

# Spreadsheet TERPISAH buat sheet sistem (Users, TargetHarga, Pengeluaran, Log, Lisensi) —
# di-share cuma ke pemilik, biar staf yang cuma butuh Viewer ke SPREADSHEET_ID gak ikut lihat data akun/log.
# Kalau gak diisi, fallback ke SPREADSHEET_ID yang sama (semua jadi 1 file).
SYSTEM_SPREADSHEET_ID=1EBrRQgPF3xNdHsmSuPwQrPzdZ1h1k4wKGYGPn26BmyM

# Service Account (Google Cloud Console > IAM > Service Accounts > buat key JSON)
# Share KEDUA spreadsheet di atas ke email service account ini (Editor access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Random string buat sign JWT session, generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-random-string-panjang

# Passcode buat halaman /dev (pengaturan lisensi, developer-only)
DEV_PASSCODE=ganti-dengan-passcode-rahasia
